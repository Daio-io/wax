{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wax.dev/schemas/waxrc.v1.schema.json",
  "title": "wax config v1",
  "description": "Repository wax configuration. Canonical path is .wax/wax.config.json; legacy .waxrc is still accepted. The $id remains waxrc.v1 for editor and tooling compatibility.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "languages"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scan_concurrency": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "adoption": {
      "type": "object",
      "additionalProperties": false,
      "description": "Adoption Metrics v2 scan behavior and reporting limits.",
      "properties": {
        "track_local_invocations": {
          "type": "boolean",
          "description": "When true, parser-backed packs emit local invocation facts."
        },
        "track_unresolved_invocations": {
          "type": "boolean",
          "description": "When true, parser-backed packs emit unresolved UI invocation facts."
        },
        "parent_attribution": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "When true, usage sites include parent scope attribution."
            },
            "scope_visibility": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["public", "internal", "private"]
              },
              "description": "Which parent scope visibilities are included in attribution."
            }
          }
        },
        "candidate_policy": {
          "type": "string",
          "enum": ["report_separately", "count_as_non_adopted", "count_as_adopted"],
          "description": "How candidate invocations affect primary adoption counters."
        },
        "symbol_usage_summary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "When true, derived symbol_usage_summary rows are emitted."
            },
            "parent_scope_limit": {
              "type": ["integer", "null"],
              "minimum": 0,
              "description": "null emits all parent rows; 0 emits none; N limits rows per symbol."
            }
          }
        }
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "enabled"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "enabled": {
            "type": "boolean"
          },
          "registry": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["source"],
                "properties": {
                  "source": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          },
          "design_system_registry": {
            "type": "string",
            "minLength": 1,
            "description": "Deprecated. Use registry instead. When both registry and design_system_registry are set, registry wins at runtime."
          }
        },
        "additionalProperties": true
      }
    }
  }
}
