{
  "schema_version": 2,
  "engine": {
    "scan_concurrency": 2
  },
  "languages": {
    "compose": {
      "roots": [
        "app/src/main/kotlin"
      ]
    },
    "react": {
      "roots": [
        "apps/web/src"
      ]
    },
    "swift": {
      "registry": ".wax/swift.registry.json",
      "roots": [
        "App/Sources"
      ]
    }
  }
}
