{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wax.dev/schemas/scan-facts.v2.schema.json",
  "title": "ScanFacts",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "language",
    "snapshot_id",
    "scanned_at",
    "status",
    "design_system_components",
    "local_components",
    "usage_sites",
    "diagnostics",
    "metrics",
    "counts"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "language": { "$ref": "#/$defs/language_metadata" },
    "snapshot_id": { "type": "string", "minLength": 1 },
    "scanned_at": { "type": "string", "format": "date-time" },
    "status": { "$ref": "#/$defs/scan_status" },
    "design_system_components": {
      "type": "array",
      "items": { "$ref": "#/$defs/design_system_component" }
    },
    "local_components": {
      "type": "array",
      "items": { "$ref": "#/$defs/local_component" }
    },
    "usage_sites": {
      "type": "array",
      "items": { "$ref": "#/$defs/usage_site" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "metrics": { "$ref": "#/$defs/metrics" },
    "counts": { "$ref": "#/$defs/count_summary" },
    "symbol_usage_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/symbol_usage_summary" }
    }
  },
  "$defs": {
    "language_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "language_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "ecosystem", "parser_name", "parser_version"],
      "properties": {
        "id": { "$ref": "#/$defs/language_id" },
        "version": { "type": "string", "minLength": 1 },
        "ecosystem": { "type": "string", "minLength": 1 },
        "parser_name": { "type": "string", "minLength": 1 },
        "parser_version": { "type": "string", "minLength": 1 }
      }
    },
    "source_location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
        "column": { "type": "integer", "minimum": 1, "maximum": 4294967295 }
      }
    },
    "scan_status": {
      "type": "string",
      "enum": ["complete", "partial", "failed"]
    },
    "match_status": {
      "type": "string",
      "enum": ["resolved", "candidate", "local", "unresolved"],
      "description": "How one UI invocation resolved: resolved (registry), local (in-repo), candidate (ambiguous), unresolved (UI-shaped but unmatched)."
    },
    "symbol_kind": {
      "type": "string",
      "enum": ["registry", "local", "candidate", "unresolved"],
      "description": "What a symbol_usage_summary row represents after grouping usage sites."
    },
    "identity_stability": {
      "type": "string",
      "enum": ["semantic", "path_sensitive", "scan_local"],
      "description": "Expected durability of an ID for trend consumers."
    },
    "diagnostic_severity": {
      "type": "string",
      "enum": ["error", "warning", "info"]
    },
    "design_system_component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "symbol", "registry_symbol"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "registry_symbol": { "type": "string", "minLength": 1 }
      }
    },
    "local_component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "symbol", "location"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "qualified_symbol": { "type": "string", "minLength": 1 },
        "identity_basis": { "type": "string", "minLength": 1 },
        "identity_stability": { "$ref": "#/$defs/identity_stability" },
        "location": { "$ref": "#/$defs/source_location" }
      }
    },
    "parent_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_id",
        "symbol",
        "scope_kind",
        "identity_basis",
        "identity_stability"
      ],
      "properties": {
        "parent_id": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "qualified_symbol": { "type": "string", "minLength": 1 },
        "scope_kind": { "type": "string", "minLength": 1 },
        "identity_basis": { "type": "string", "minLength": 1 },
        "identity_stability": { "$ref": "#/$defs/identity_stability" },
        "location": { "$ref": "#/$defs/source_location" }
      }
    },
    "usage_site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "location", "symbol", "match_status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/source_location" },
        "symbol": { "type": "string", "minLength": 1 },
        "qualified_symbol": { "type": "string", "minLength": 1 },
        "match_status": { "$ref": "#/$defs/match_status" },
        "registry_symbol": { "type": "string", "minLength": 1 },
        "local_definition_id": { "type": "string", "minLength": 1 },
        "parent": { "$ref": "#/$defs/parent_scope" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "match_status": { "const": "resolved" } },
            "required": ["match_status"]
          },
          "then": { "required": ["registry_symbol"], "not": { "required": ["local_definition_id"] } }
        },
        {
          "if": {
            "properties": { "match_status": { "const": "candidate" } },
            "required": ["match_status"]
          },
          "then": { "required": ["registry_symbol"], "not": { "required": ["local_definition_id"] } }
        },
        {
          "if": {
            "properties": { "match_status": { "const": "local" } },
            "required": ["match_status"]
          },
          "then": { "required": ["local_definition_id"], "not": { "required": ["registry_symbol"] } }
        },
        {
          "if": {
            "properties": { "match_status": { "const": "unresolved" } },
            "required": ["match_status"]
          },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["registry_symbol"] },
                { "required": ["local_definition_id"] }
              ]
            }
          }
        }
      ]
    },
    "symbol_parent_scope_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_id",
        "symbol",
        "scope_kind",
        "identity_basis",
        "identity_stability",
        "invocation_count"
      ],
      "properties": {
        "parent_id": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "qualified_symbol": { "type": "string", "minLength": 1 },
        "scope_kind": { "type": "string", "minLength": 1 },
        "identity_basis": { "type": "string", "minLength": 1 },
        "identity_stability": { "$ref": "#/$defs/identity_stability" },
        "invocation_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "location": { "$ref": "#/$defs/source_location" }
      }
    },
    "symbol_usage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol_id",
        "symbol",
        "symbol_kind",
        "match_status",
        "identity_basis",
        "identity_stability",
        "raw_invocation_count",
        "parent_scope_count",
        "file_count",
        "parent_scopes",
        "parent_scopes_truncated"
      ],
      "properties": {
        "symbol_id": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "qualified_symbol": { "type": "string", "minLength": 1 },
        "symbol_kind": { "$ref": "#/$defs/symbol_kind" },
        "match_status": { "$ref": "#/$defs/match_status" },
        "registry_symbol": { "type": "string", "minLength": 1 },
        "local_definition_id": { "type": "string", "minLength": 1 },
        "identity_basis": { "type": "string", "minLength": 1 },
        "identity_stability": { "$ref": "#/$defs/identity_stability" },
        "raw_invocation_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "parent_scope_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "file_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "parent_scopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/symbol_parent_scope_summary" }
        },
        "parent_scope_limit": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 4294967295,
          "description": "null emits all parent rows; 0 emits none but preserves parent_scope_count; N emits up to N rows."
        },
        "parent_scopes_truncated": {
          "type": "boolean",
          "description": "True when parent_scopes omits rows because parent_scope_limit was applied."
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "message"],
      "properties": {
        "severity": { "$ref": "#/$defs/diagnostic_severity" },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "location": { "$ref": "#/$defs/source_location" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invocation_adoption_ratio",
        "registry_resolution_ratio",
        "parse_extract_ms",
        "files_scanned"
      ],
      "properties": {
        "invocation_adoption_ratio": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "adopted_invocation_count / eligible_invocation_count; null when eligible is zero."
        },
        "registry_resolution_ratio": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "raw_invocations.resolved / raw_invocations.total; null when total is zero."
        },
        "parse_extract_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295,
          "description": "Practical contract maximum matching runtime validation."
        },
        "files_scanned": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    },
    "registry_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_count",
        "used_component_count",
        "resolved_raw_invocation_count",
        "candidate_raw_invocation_count"
      ],
      "properties": {
        "component_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "used_component_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "resolved_raw_invocation_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "candidate_raw_invocation_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    },
    "definition_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_definition_count",
        "invoked_local_definition_count",
        "unused_local_definition_count"
      ],
      "properties": {
        "local_definition_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "invoked_local_definition_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "unused_local_definition_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    },
    "raw_invocation_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "resolved", "local", "candidate", "unresolved"],
      "properties": {
        "total": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "resolved": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "local": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "candidate": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "unresolved": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    },
    "adoption_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eligible_invocation_count",
        "adopted_invocation_count",
        "non_adopted_invocation_count"
      ],
      "properties": {
        "eligible_invocation_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "adopted_invocation_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "non_adopted_invocation_count": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    },
    "parent_scope_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "with_resolved_invocations",
        "with_local_invocations",
        "with_unresolved_invocations"
      ],
      "properties": {
        "total": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "with_resolved_invocations": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "with_local_invocations": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "with_unresolved_invocations": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    },
    "count_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry", "definitions", "raw_invocations", "adoption", "parent_scopes"],
      "properties": {
        "registry": { "$ref": "#/$defs/registry_counts" },
        "definitions": { "$ref": "#/$defs/definition_counts" },
        "raw_invocations": { "$ref": "#/$defs/raw_invocation_counts" },
        "adoption": { "$ref": "#/$defs/adoption_counts" },
        "parent_scopes": { "$ref": "#/$defs/parent_scope_counts" }
      }
    }
  }
}
