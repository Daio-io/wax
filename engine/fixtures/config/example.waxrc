{
  "schema_version": 1,
  "engine": {
    "scan_concurrency": 2
  },
  "languages": [
    {
      "id": "compose",
      "enabled": true,
      "roots": ["app/src/main/kotlin"]
    },
    {
      "id": "react",
      "enabled": true,
      "roots": ["apps/web/src"]
    },
    {
      "id": "swift",
      "enabled": true,
      "registry": ".wax/swift.registry.json",
      "roots": ["App/Sources"]
    }
  ]
}
