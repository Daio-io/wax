{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wax.dev/schemas/waxrc.v1.schema.json",
  "title": "wax config v1",
  "description": "Repository wax configuration. Canonical path is .wax/wax.config.json; legacy .waxrc is still accepted. The $id remains waxrc.v1 for editor and tooling compatibility.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "languages"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scan_concurrency": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "enabled"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "enabled": {
            "type": "boolean"
          },
          "registry": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["source"],
                "properties": {
                  "source": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          },
          "design_system_registry": {
            "type": "string",
            "minLength": 1,
            "description": "Deprecated. Use registry instead. When both registry and design_system_registry are set, registry wins at runtime."
          }
        },
        "additionalProperties": true
      }
    }
  }
}
